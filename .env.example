# API Configuration
DIVERGRAM_API_BASE=https://api.divergram.com
EXPO_PUBLIC_DIVERGRAM_API_BASE=https://api.divergram.com
EXPO_PUBLIC_API_BASE_URL=https://api.divergram.com

# OAuth Configuration - Google
GOOGLE_CLIENT_ID_IOS=your-google-client-id-ios
GOOGLE_CLIENT_ID_ANDROID=your-google-client-id-android
GOOGLE_CLIENT_ID_WEB=your-google-client-id-web
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth Configuration - Apple
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key

# OAuth Configuration - Facebook
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# OAuth Configuration - Kakao
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_JAVASCRIPT_KEY=your-kakao-javascript-key
KAKAO_NATIVE_APP_KEY=your-kakao-native-app-key
KAKAO_REDIRECT_URI=divergram://auth/kakao

# OAuth Configuration - Naver
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_REDIRECT_URI=divergram://auth/naver

# Analytics & Monitoring
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-optional

# Environment
NODE_ENV=development

# Database
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=divergram
PGUSER=postgres
PGPASSWORD=postgres
# Optional for seed scripts (preferred if set)
DATABASE_URL=

# Server Core
JWT_SECRET=your-jwt-secret
ADMIN_API_KEY=your-admin-api-key
PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Web / Vite
VITE_API_BASE_URL=http://localhost:3000
VITE_ADMIN_API_BASE=http://localhost:3000
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional integrations
OPENAI_API_KEY=
API_PUBLIC_BASE_URL=http://localhost:3000

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@example.com

# Session / Callback
OAUTH_CALLBACK_BASE_URL=http://localhost:3000
WEB_APP_BASE_URL=http://localhost:5173
SESSION_COOKIE_DOMAIN=localhost
