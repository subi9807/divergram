# Divergram API server env
PORT=

# CORS
CORS_ORIGINS=

# DB
PGHOST=
PGPORT=
PGDATABASE=
PGUSER=
PGPASSWORD=

# Security
JWT_SECRET=
ADMIN_API_KEY=

# Upload storage
UPLOAD_DIR=
UPLOAD_BASE_URL=
MAX_UPLOAD_MB=

# OAuth
OAUTH_CALLBACK_BASE_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# SMTP (Gmail App Password)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
WEB_APP_BASE_URL=

# Push notifications (Firebase Cloud Messaging)
# Either paste the service account JSON or point to a file path.
FCM_SERVICE_ACCOUNT_JSON=
FCM_SERVICE_ACCOUNT_PATH=

# Topic used for broadcast pushes
FCM_ALL_USERS_TOPIC=all_users
