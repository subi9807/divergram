{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "channel": "production",
      "autoIncrement": false,
      "env": {
        "EXPO_USE_PRECOMPILED_MODULES": "0"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6769253236"
      },
      "android": {
        "serviceAccountKeyPath": "./.secrets/google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
