{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "channel": "production",
      "autoIncrement": false
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./.secrets/google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
