{
  "name": "divergram",
  "main": "./index.js",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start --port 8081 --tunnel --non-interactive",
    "dev:web": "EXPO_NO_TELEMETRY=1 expo start --web --port 8081",
    "dev:ios": "EXPO_NO_TELEMETRY=1 expo start --ios --port 8081",
    "dev:android": "EXPO_NO_TELEMETRY=1 expo start --android --port 8081",
    "build:web": "expo export --platform web",
    "build:ios": "npx eas-cli build --platform ios --profile production",
    "build:android": "npx eas-cli build --platform android --profile production",
    "build:android:local:release": "cd android && ./gradlew :app:assembleRelease -PreactNativeArchitectures=arm64-v8a -x lintVitalAnalyzeRelease",
    "build:android:local:aab": "cd android && ./gradlew :app:bundleRelease -PreactNativeArchitectures=arm64-v8a -x lintVitalAnalyzeRelease",
    "lint": "expo lint",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "android:release": "expo run:android --variant release",
    "ios:release": "expo run:ios --configuration Release",
    "postinstall": "node scripts/fix-expo-xcframework.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@heroicons/react": "^2.2.0",
    "@lucide/lab": "^0.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^25.1.0",
    "@react-native-firebase/messaging": "^25.1.0",
    "@tanstack/react-query": "^5.90.2",
    "@types/i18next": "^13.0.0",
    "@types/react": "~19.0.10",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~56.0.12",
    "expo-apple-authentication": "~56.0.4",
    "expo-auth-session": "~56.0.14",
    "expo-background-fetch": "~56.0.19",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.19",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.17",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-location": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.19",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "i18next": "^25.5.2",
    "lucide-react": "^1.17.0",
    "lucide-react-native": "^0.475.0",
    "nativewind": "^4.2.1",
    "playwright-core": "^1.60.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^15.7.3",
    "react-native": "0.85.3",
    "react-native-ble-plx": "^3.5.0",
    "react-native-chart-kit": "^6.12.0",
