    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "3.3.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.14",
    "autoprefixer": "^10.5.0",
    "eas-cli": "^20.2.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3"
  }
