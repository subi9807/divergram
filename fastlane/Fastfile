def app_store_api_key
  return nil unless ENV['ASC_API_KEY_ID'] && ENV['ASC_API_KEY_PATH']

  app_store_connect_api_key(
    key_id: ENV['ASC_API_KEY_ID'],
    issuer_id: ENV['ASC_API_ISSUER_ID'],
    key_filepath: ENV['ASC_API_KEY_PATH'],
    duration: 1200,
    in_house: false
  )
end

platform :ios do
  desc 'App Store Connect 메타데이터/스크린샷/미리보기 업로드 (빌드 업로드 제외)'
  lane :upload_store_assets do
    skip_screenshots_env = ENV['SKIP_SCREENSHOTS'] == '1'
    skip_metadata_env = ENV['SKIP_METADATA'] == '1'

    options = {
      app_identifier: ENV.fetch('APP_IDENTIFIER', 'com.divergram.app.ios'),
      force: true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      skip_binary_upload: true,
      skip_metadata: skip_metadata_env,
      skip_screenshots: skip_screenshots_env,
      overwrite_screenshots: true,
      app_previews_path: 'fastlane/preview',
      overwrite_preview_videos: true,
      ignore_language_directory_validation: true,
      precheck_include_in_app_purchases: false,
      metadata_path: 'fastlane/metadata',
      screenshots_path: 'fastlane/screenshots'
    }

    if skip_screenshots_env
      options.delete(:screenshots_path)
      options.delete(:overwrite_screenshots)
      options.delete(:app_previews_path)
      options.delete(:overwrite_preview_videos)
    end

    api_key = app_store_api_key
    if api_key
      options[:api_key] = api_key
    else
      options[:username] = ENV.fetch('APPSTORECONNECT_USER')
      # app_specific_password is optional for metadata/screenshots flows when session auth is used
      options[:app_specific_password] = ENV['APPSTORECONNECT_APP_PASSWORD'] if ENV['APPSTORECONNECT_APP_PASSWORD']
      options[:itc_provider] = ENV['APPSTORE_PROVIDER_ID'] if ENV['APPSTORE_PROVIDER_ID']
    end

    deliver(options)
  end
end
